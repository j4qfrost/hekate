{
  "title": "hekate — Venue users + Events processing",
  "uid": "hekate-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["hekate", "atproto"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "ds",
        "label": "Metrics datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Venue users",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Distinct authoring DIDs (1h)",
      "description": "Count of unique DIDs publishing app.hekate.* records in the last hour.",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "count(count by (hekate_did) (rate(hekate_firehose_events_total[1h])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "color": { "mode": "thresholds" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Venues created / updated / deleted",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "sum by (action) (rate(hekate_firehose_events_total{collection=\"app.hekate.venue\"}[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Venue records indexed (after validation)",
      "description": "Records that passed indexer validation and were materialised into the venues table.",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "sum by (action) (rate(hekate_indexer_records_indexed_total{collection=\"app.hekate.venue\"}[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Events processing",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Slot lifecycle: open → claimed → cancelled",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum by (action) (rate(hekate_firehose_events_total{collection=\"app.hekate.slot\"}[5m]))",
          "legendFormat": "slot {{action}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(hekate_firehose_events_total{collection=\"app.hekate.event\", action=\"create\"}[5m]))",
          "legendFormat": "event create (claim attempts)",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "RSVPs (going / maybe / declined)",
      "description": "Note: indexer collapses multiple RSVPs from the same DID for the same event.",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "sum by (action) (rate(hekate_firehose_events_total{collection=\"app.hekate.rsvp\"}[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Recurrence slots materialised",
      "description": "Output of the daily recurrence-expander tick; spikes daily by design.",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "rate(hekate_recurrence_slots_materialized_total[15m])",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 9,
      "type": "row",
      "title": "Indexer health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Firehose decode errors by reason",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(hekate_firehose_decode_errors_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Indexer validation errors by reason",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "targets": [
        {
          "expr": "sum by (collection, reason) (rate(hekate_indexer_validation_errors_total[5m]))",
          "legendFormat": "{{collection}} / {{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Commit handle p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(hekate_firehose_handle_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(hekate_firehose_handle_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(hekate_firehose_handle_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "HTTP read API: requests / sec by route",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum by (http_route, http_response_status_code) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{http_route}} {{http_response_status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
